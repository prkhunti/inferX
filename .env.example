# Backend selection: "openai" | "echo"
# Use "echo" to run locally without an API key (no network calls, simulated latency).
# Use "openai" (or any OpenAI-compatible endpoint) to benchmark a real model.
BACKEND_TYPE=echo

# Required only when BACKEND_TYPE=openai
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=         # optional: override for Together, Groq, local vLLM, etc.

DATABASE_URL=postgresql+asyncpg://inferx:inferx@localhost:5432/inferx
REDIS_URL=redis://localhost:6379/0
DEBUG=false
