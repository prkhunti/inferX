# Backend selection: "echo" runs locally without external credentials.
# Use "openai" for OpenAI or another OpenAI-compatible provider.
BACKEND_TYPE=echo

# Required only when BACKEND_TYPE=openai.
OPENAI_API_KEY=replace-with-provider-key

# Optional OpenAI-compatible endpoint override.
# Examples: http://localhost:8001/v1, https://api.openai.com/v1
# OPENAI_BASE_URL=

# Used when running the Python API directly on the host.
# Docker Compose injects postgres:5432 for the API container.
DATABASE_URL=postgresql+asyncpg://inferx:inferx@localhost:5433/inferx
REDIS_URL=redis://localhost:6379/0

DEBUG=false

# Used by the dashboard rewrite proxy when running outside Docker.
NEXT_PUBLIC_API_URL=http://localhost:8000
